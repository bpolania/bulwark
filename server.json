{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.bpolania/bulwark",
  "title": "Bulwark",
  "description": "AI agent governance: content scanning, audit logs, policy evaluation, session management.",
  "repository": {
    "url": "https://github.com/bpolania/bulwark",
    "source": "github"
  },
  "websiteUrl": "https://github.com/bpolania/bulwark",
  "version": "0.2.0",
  "packages": [
    {
      "registryType": "oci",
      "identifier": "ghcr.io/bpolania/bulwark:0.2.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        },
        {
          "type": "positional",
          "value": "start"
        }
      ],
      "environmentVariables": [
        {
          "name": "BULWARK_CONFIG",
          "description": "Path to bulwark.yaml configuration file",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "BULWARK_SESSION_TOKEN",
          "description": "Session token for operator authentication (bwk_sess_...)",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
